# Campaign Skills — Project Configuration Template
#
# `python scripts/task_manager.py init --force` renders this file into
# `.claude/skills/project.toml` using local project detection.
# Keep this template generic and portable.

[project]
name = {{PROJECT_NAME}}
conventions = {{CONVENTIONS_PATH}}

[paths]
state = "data/tasks.json"
plans = "data/plans"
specs = "agents/"
tracker = "live-tracker.md"

[commands]
{{TEST_LINE}}
{{TEST_FAST_LINE}}
{{TEST_FULL_LINE}}
{{COMPILE_LINE}}
{{BUILD_LINE}}

